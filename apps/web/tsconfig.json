{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/content" }
  ]
}
