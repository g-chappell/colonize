# Environment & secrets
.env
.env.local
.env.*.local

# Capacitor — generated/copied, regenerated on every `cap sync`
apps/mobile/ios/App/App/public/
apps/mobile/android/app/src/main/assets/public/
apps/mobile/ios/App/App/capacitor.config.json
apps/mobile/android/app/src/main/assets/capacitor.config.json
apps/mobile/android/app/src/main/assets/capacitor.plugins.json

# Capacitor — native build outputs (IDE + build-tool artifacts)
apps/mobile/ios/App/build/
apps/mobile/ios/App/Pods/
apps/mobile/ios/App/Podfile.lock
apps/mobile/ios/DerivedData/
apps/mobile/ios/App/App/xcuserdata/
apps/mobile/android/app/build/
apps/mobile/android/build/
apps/mobile/android/.gradle/
apps/mobile/android/local.properties
apps/mobile/android/app/release/
apps/mobile/android/app/debug/

# Build outputs
dist/
build/
out/
.next/
.nuxt/
target/
*.tsbuildinfo
*.pyc
__pycache__/
.pytest_cache/

# Dependencies
node_modules/
vendor/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Claude Code state
.claude/.setup-progress
# Per-machine Bash permission allow-list — mutated by Claude Code on every
# interactive session as new commands are approved. Untracked state here
# fails `/autonomous-run`'s strict clean-tree precheck when the scheduled
# agent runs as a different OS user (no personal core.excludesFile).
.claude/settings.local.json
# Hook-written observability logs (InstructionsLoaded, etc.) — grow
# unbounded and contain absolute paths specific to the machine.
.claude/logs/

# Approvals (history.md, PENDING.md, and archived approvals) ARE committed
# per the branch-as-payload / auditable-approvals design.

# Deploy artifacts (transient, local only)
scripts/.deploy-lock
scripts/.previous-image

# Generated texture atlases — packed by packages/content/scripts/pack-atlas.mjs
packages/content/atlas-out/

# Atlases copied into the web app's public/ at predev/prebuild time.
apps/web/public/atlas/

# Generated silent WAV stems — packed by packages/content/scripts/generate-placeholder-audio.mjs
packages/content/audio-out/

# Audio copied into the web app's public/ at predev/prebuild time.
apps/web/public/audio/
