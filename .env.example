# Environment variables template.
# Copy to .env (gitignored) on the host machine and fill in real values.
#
# DO NOT commit .env. This .example file is safe to commit.

# --- Claude / Anthropic ---
# Required if CC runs on a VPS and makes API calls directly.
ANTHROPIC_API_KEY=

# --- GitHub (for the autonomous agent) ---
# gh CLI uses its own auth (~/.config/gh/) by default; set this only if you
# want the agent to use a specific token different from `gh auth`.
GITHUB_TOKEN=

# --- Database (example — replace with your app's needs) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=app
DATABASE_URL=postgresql://app:change-me-in-prod@db:5432/app

# --- Your app's secrets (add as needed) ---
# JWT_SECRET=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# STRIPE_KEY=

# --- Port the app listens on (nginx proxies here) ---
APP_PORT=3000
