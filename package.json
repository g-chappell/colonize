{
  "name": "colonize",
  "version": "0.0.0",
  "private": true,
  "description": "Colonize — 2D retro 4X reimagining of Sid Meier's Colonization, set in the Order of the Kraken universe",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "node scripts/run-workspaces.mjs typecheck",
    "test:scripts": "node --test scripts/",
    "test": "node --test scripts/ && node scripts/run-workspaces.mjs test",
    "lint": "eslint .",
    "build": "node scripts/run-workspaces.mjs build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "npm run dev --workspace=apps/web"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.19.0"
  }
}
